# ============================================
# Cold Call Platform — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ============================================

# --- Base de donnees ---
POSTGRES_USER=coldcall
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=coldcall
DATABASE_URL=postgresql+asyncpg://coldcall:changeme_strong_password@db:5432/coldcall

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- JWT Auth ---
JWT_SECRET_KEY=changeme_generate_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# --- OAuth2 Google ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8092/api/auth/google/callback

# --- OAuth2 GitHub ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8092/api/auth/github/callback

# --- Twilio (telephonie) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_TWIML_APP_SID=
TWILIO_API_KEY=
TWILIO_API_SECRET=

# --- Outscraper (scraping) ---
OUTSCRAPER_API_KEY=

# --- Foursquare (complement gratuit) ---
FOURSQUARE_API_KEY=

# --- Stripe (paiements) ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Sentry (monitoring) ---
SENTRY_DSN=

# --- App ---
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8092
CORS_ORIGINS=http://localhost:8092,http://localhost:3000
